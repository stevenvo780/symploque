{
  "name": "@elenxos/design-system",
  "version": "0.1.0",
  "type": "module",
  "description": "Elenxos Design System — Mononoke × Logic aesthetic components for React",
  "license": "MIT",
  "main": "./dist/elenxos-design-system.cjs.js",
  "module": "./dist/elenxos-design-system.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/elenxos-design-system.es.js",
      "require": "./dist/elenxos-design-system.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/style.css",
    "./tokens": "./src/utils/tokens.ts"
  },
  "files": [
    "dist",
    "src/tokens",
    "src/utils/tokens.ts"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --mode lib",
    "preview": "vite preview",
    "render": "tsx scripts/render-images.ts",
    "render:all": "tsx scripts/render-images.ts --all",
    "render:video": "tsx scripts/render-video.ts",
    "render:video:all": "tsx scripts/render-video.ts --all",
    "campaign": "tsx scripts/generate-campaign.ts",
    "campaign:dolor": "tsx scripts/generate-campaign.ts --narrativa dolor",
    "campaign:solucion": "tsx scripts/generate-campaign.ts --narrativa solucion",
    "campaign:ecosistema": "tsx scripts/generate-campaign.ts --narrativa ecosistema"
  },
  "dependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "playwright": "^1.59.1",
    "sass": "^1.77.0",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
